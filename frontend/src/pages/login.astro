---
import "../styles/global.css";
import { initUsersTable } from "../lib/users";
 
// Initialize users table on first load
await initUsersTable();
---
 
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Login - BETA-CODE</title>
  </head>
  <body>
    <header class="site-header">
      <h1>Beta-code</h1>
      <nav class="site-nav">
        <a href="/">Home</a>
        <a href="/play">Tasks</a>
        <a href="/signup">Sign Up</a>
        <a href="/login">Login</a>
      </nav>
    </header>
 
    <main class="auth-page">
      <div class="auth-card">
        <h2>Login</h2>
        <p class="auth-subtitle">Welcome back! Sign in to continue.</p>
 
        <form id="login-form" class="auth-form">
          <div class="form-group">
            <label for="username" class="form-label">Username</label>
            <input
              type="text"
              id="username"
              name="username"
              required
              minlength="3"
              maxlength="30"
              pattern="[a-zA-Z0-9_]+"
              autocomplete="username"
              placeholder="Enter your username"
            />
          </div>
 
          <div class="form-group">
            <label for="password" class="form-label">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              minlength="6"
              autocomplete="current-password"
              placeholder="Enter your password"
            />
          </div>
 
          <button type="submit" class="auth-button">Login</button>
 
          <p id="status-message" class="status-message"></p>
        </form>
 
        <p class="auth-footer">
          Don't have an account? <a href="/signup">Sign up</a>
        </p>
      </div>
    </main>
 
    <style>
      .auth-page {
        max-width: 400px;
        margin: 40px auto;
        padding: 0 16px;
      }
 
      .auth-card {
        background: #111b2b;
        border-radius: 16px;
        padding: 32px;
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.25);
      }
 
      .auth-card h2 {
        margin: 0 0 8px 0;
        text-align: center;
      }
 
      .auth-subtitle {
        color: var(--small-text);
        text-align: center;
        margin: 0 0 24px 0;
      }
 
      .auth-form {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
 
      .form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
        text-align: left;
      }
 
      .form-label {
        font-weight: 600;
        font-size: 0.9rem;
      }
 
      .auth-form input {
        width: 100%;
        border-radius: 8px;
        border: 1px solid #2d3f5f;
        background: #0c1420;
        color: var(--text-color);
        padding: 12px 14px;
        font-size: 1rem;
        box-sizing: border-box;
        transition: border-color 0.2s;
      }
 
      .auth-form input:focus {
        outline: none;
        border-color: var(--beta-blue);
      }
 
      .auth-form input::placeholder {
        color: #5a6a8a;
      }
 
      .auth-button {
        background: var(--beta-blue);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 12px 16px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 8px;
      }
 
      .auth-button:hover {
        background: rgb(0, 110, 210);
      }
 
      .auth-button:disabled {
        background: #4a5a7a;
        cursor: not-allowed;
      }
 
      .status-message {
        text-align: center;
        margin: 8px 0 0 0;
        min-height: 20px;
      }
 
      .status-message.error {
        color: #ff6b6b;
      }
 
      .status-message.success {
        color: #51cf66;
      }
 
      .auth-footer {
        text-align: center;
        margin-top: 24px;
        color: var(--small-text);
      }
 
      .auth-footer a {
        color: var(--beta-blue);
        text-decoration: none;
      }
 
      .auth-footer a:hover {
        text-decoration: underline;
      }
    </style>
 
    <script>
      const form = document.getElementById("login-form") as HTMLFormElement;
      const statusMessage = document.getElementById("status-message") as HTMLParagraphElement;
      const submitButton = form.querySelector("button[type='submit']") as HTMLButtonElement;
 
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
 
        const formData = new FormData(form);
        const username = formData.get("username") as string;
        const password = formData.get("password") as string;
 
        statusMessage.textContent = "";
        statusMessage.className = "status-message";
        submitButton.disabled = true;
        submitButton.textContent = "Logging in...";
 
        try {
          const response = await fetch("/api/login", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ username, password }),
          });
 
          const data = await response.json();
 
          if (data.success) {
            statusMessage.textContent = "Login successful! Redirecting...";
            statusMessage.className = "status-message success";
            setTimeout(() => {
              window.location.href = "/profile";
            }, 1000);
          } else {
            statusMessage.textContent = data.error || "Login failed";
            statusMessage.className = "status-message error";
            submitButton.disabled = false;
            submitButton.textContent = "Login";
          }
        } catch (error) {
          statusMessage.textContent = "An error occurred. Please try again.";
          statusMessage.className = "status-message error";
          submitButton.disabled = false;
          submitButton.textContent = "Login";
        }
      });
    </script>
  </body>
</html>