---
import "../../styles/global.css";

const problems = [
  { id: "1", title: "A + B", points: 50 },
  { id: "2", title: "FizzBuzz", points: 75 },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Problems</title>
  </head>
  <body>
    <header>
      <h1>Problems</h1>
    </header>

    <main style="max-width: 900px; margin: 0 auto; padding: 16px;">
      <ul>
        {problems.map((p) => (
          <li>
            <a href={`/problem/${p.id}`}>{p.title}</a> — {p.points} pts
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>
